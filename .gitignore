# Create .gitignore in the main project folder
New-Item -Path .gitignore -ItemType File -Force

# Add the essential entries
@"
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.production

# Build outputs
dist/
build/
.next/
out/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Database
*.sqlite
*.db
"@ | Out-File -FilePath .gitignore -Encoding UTF8